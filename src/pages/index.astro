---
import Layout from '../layouts/Layout.astro';
import property from '../data/property.json';
import CorporateProximity from '../components/CorporateProximity.astro';
import ExecutiveTimeline from '../components/ExecutiveTimeline.astro';

const dna = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
    label: 'EV Charging', sub: 'On-site station'
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636"/></svg>`,
    label: 'Steam Sauna', sub: 'Primary suite'
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    label: 'Gated Security', sub: 'Ring + auto gate'
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c-4.97 0-9 3.185-9 7.5S7.03 18 12 18s9-3.185 9-7.5S16.97 3 12 3zm0 0v15m0-15C9 3 6.5 6.5 6.5 10.5M12 3c3 0 5.5 3.5 5.5 7.5M3 10.5h18"/></svg>`,
    label: 'Heated Pool', sub: 'Gas-heated, filtered'
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/></svg>`,
    label: "Chef's Kitchen", sub: 'Dual ovens & sinks'
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819"/></svg>`,
    label: 'Guest House', sub: '~400 sq ft ADU'
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z"/></svg>`,
    label: 'Smart Home', sub: 'Multi-zone HVAC + lighting'
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>`,
    label: '4,492 Sq Ft', sub: 'Combined living space'
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "RealEstateListing",
    "name": "9432 Oakmore Rd — Luxury 5BR Rental | Beverlywood Los Angeles",
    "description": property.description,
    "url": "https://rentlaelite.theissakgroup.workers.dev",
    "image": [
      `https://rentlaelite.theissakgroup.workers.dev${property.images.hero}`,
      `https://rentlaelite.theissakgroup.workers.dev${property.images.exterior[0]}`,
      `https://rentlaelite.theissakgroup.workers.dev${property.images.outdoor[0]}`
    ],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": property.address.street,
      "addressLocality": property.address.city,
      "addressRegion": property.address.state,
      "postalCode": property.address.zip,
      "addressCountry": "US"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": "34.0503", "longitude": "-118.3847" },
    "numberOfRooms": property.beds,
    "floorSize": { "@type": "QuantitativeValue", "value": property.sqft, "unitCode": "FTK" },
    "offers": {
      "@type": "Offer",
      "price": property.price,
      "priceCurrency": "USD",
      "priceSpecification": { "@type": "UnitPriceSpecification", "price": property.price, "priceCurrency": "USD", "unitText": "MON" }
    },
    "broker": { "@type": "RealEstateAgent", "name": property.agent.name, "telephone": property.agent.phone, "email": property.agent.email }
  },
  {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": property.video.title,
    "description": property.video.description,
    "thumbnailUrl": property.video.thumbnailUrl,
    "uploadDate": "2025-01-22T08:00:00-08:00",
    "contentUrl": property.video.url,
    "embedUrl": property.video.embedUrl
  }
];
---

<Layout
  title="Luxury 5BR Rental Beverlywood LA 90035 | 9432 Oakmore Rd — $23,950/mo"
  description="Gated 5-bed luxury compound in Beverlywood, LA 90035. Heated pool, steam sauna, chef's kitchen, detached guest house. $23,950/mo. Virtual tour available."
  jsonLd={jsonLd}
>

  <!-- ═══════════════════════════════════════ CINEMATIC HERO -->
  <section class="relative h-screen min-h-[700px] flex items-center overflow-hidden">

    <!-- Ken Burns background -->
    <div class="absolute inset-0 z-0">
      <img
        src={property.images.hero}
        alt="9432 Oakmore Rd aerial — gated luxury compound Beverlywood Los Angeles 90035"
        class="w-full h-full object-cover animate-ken-burns origin-center"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-midnight-950/95 via-midnight-950/60 to-midnight-950/20"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-midnight-950 via-transparent to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Left: Hero Copy -->
      <div class="animate-fade-up">
        <p class="text-amber-400 text-xs tracking-[0.4em] uppercase mb-6 flex items-center gap-3">
          <span class="w-8 h-px bg-amber-400"></span>
          Beverlywood · Los Angeles, CA 90035
        </p>
        <h1 class="font-display text-5xl md:text-7xl leading-[1.05] mb-6">
          <span class="text-white">9432</span><br />
          <span class="text-white">Oakmore</span><br />
          <em class="text-gradient not-italic">Compound</em>
        </h1>
        <p class="text-slate-300 text-lg leading-relaxed max-w-md mb-8">
          A gated dual-structure estate in prime Beverlywood — 5 bedrooms, heated pool,
          steam sauna, and a fully independent guest house.
        </p>
        <div class="flex flex-wrap gap-4 mb-10">
          {[
            ['5', 'Beds'],
            ['6', 'Baths'],
            ['4,492', 'Sq Ft'],
          ].map(([val, label]) => (
            <div class="text-center">
              <p class="font-display text-3xl text-amber-400">{val}</p>
              <p class="text-xs text-slate-500 tracking-widest uppercase">{label}</p>
            </div>
          ))}
          <div class="w-px bg-midnight-700 self-stretch mx-2"></div>
          <div>
            <p class="font-display text-3xl text-white">$23,950</p>
            <p class="text-xs text-slate-500 tracking-widest uppercase">Per Month</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-4">
          <a href="/property" class="bg-amber-400 text-midnight-950 font-semibold text-xs tracking-widest uppercase px-8 py-4 hover:bg-amber-300 transition-all duration-300 amber-glow-hover">
            Explore Property
          </a>
          <a href="#video" class="glass text-white text-xs tracking-widest uppercase px-8 py-4 hover:border-amber-400/40 transition-all duration-300 flex items-center gap-2">
            <span class="w-5 h-5 rounded-full border border-amber-400 flex items-center justify-center">
              <svg class="w-2.5 h-2.5 text-amber-400 ml-0.5" fill="currentColor" viewBox="0 0 8 10"><path d="M0 0l8 5-8 5V0z"/></svg>
            </span>
            Video Tour
          </a>
        </div>
      </div>

      <!-- Right: Glassmorphism Inquiry Card -->
      <div class="hidden lg:block">
        <div class="glass rounded-none p-8 amber-glow max-w-sm ml-auto animate-fade-in">
          <p class="text-amber-400 text-xs tracking-[0.3em] uppercase mb-6">Schedule a Private Showing</p>
          <form class="space-y-4" name="hero-inquiry" method="POST" action="/contact">
            <input type="hidden" name="form-name" value="hero-inquiry" />
            <input
              type="text"
              name="name"
              placeholder="Your Name"
              class="w-full bg-midnight-950/60 border border-slate-700 text-white placeholder-slate-500 px-4 py-3 text-sm focus:outline-none focus:border-amber-400 transition-colors"
            />
            <input
              type="email"
              name="email"
              placeholder="Email Address"
              class="w-full bg-midnight-950/60 border border-slate-700 text-white placeholder-slate-500 px-4 py-3 text-sm focus:outline-none focus:border-amber-400 transition-colors"
            />
            <input
              type="tel"
              name="phone"
              placeholder="Phone Number"
              class="w-full bg-midnight-950/60 border border-slate-700 text-white placeholder-slate-500 px-4 py-3 text-sm focus:outline-none focus:border-amber-400 transition-colors"
            />
            <select
              name="lease-length"
              class="w-full bg-midnight-950/60 border border-slate-700 text-slate-400 px-4 py-3 text-sm focus:outline-none focus:border-amber-400 transition-colors"
            >
              <option value="">Intended Stay</option>
              <option value="30-days">30–60 Days</option>
              <option value="60-days">60–90 Days</option>
              <option value="6-months">6 Months</option>
              <option value="12-months">12+ Months</option>
            </select>
            <button
              type="submit"
              class="w-full bg-amber-400 text-midnight-950 font-semibold text-xs tracking-widest uppercase py-4 hover:bg-amber-300 transition-all duration-300"
            >
              Request Showing
            </button>
          </form>
          <p class="text-slate-600 text-xs text-center mt-4">24-hour notice required · Agent accompanies all showings</p>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 animate-bounce">
      <p class="text-slate-600 text-xs tracking-widest uppercase">Discover</p>
      <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ PROPERTY DNA -->
  <section class="py-24 bg-midnight-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-amber-400 text-xs tracking-[0.4em] uppercase mb-4 flex items-center justify-center gap-3">
          <span class="w-8 h-px bg-amber-400"></span>
          What Sets It Apart
          <span class="w-8 h-px bg-amber-400"></span>
        </p>
        <h2 class="font-display text-4xl md:text-5xl text-white">Property <em class="text-gradient">DNA</em></h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-midnight-800/50">
        {dna.map(({ icon, label, sub }) => (
          <div class="glass-light p-8 flex flex-col items-center text-center gap-4 group hover:border-amber-400/20 transition-all duration-500">
            <div class="text-amber-400 group-hover:scale-110 transition-transform duration-300" set:html={icon} />
            <div>
              <p class="text-white font-medium text-sm">{label}</p>
              <p class="text-slate-500 text-xs mt-1">{sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ AERIAL STRIP -->
  <section class="grid grid-cols-4 gap-px bg-midnight-950">
    {property.images.aerial.map((src, i) => (
      <div class="overflow-hidden aspect-video">
        <img
          src={src}
          alt={`9432 Oakmore Rd aerial drone view ${i+1} — Beverlywood luxury compound`}
          class="w-full h-full object-cover opacity-70 hover:opacity-100 hover:scale-105 transition-all duration-700"
          loading="lazy"
        />
      </div>
    ))}
  </section>

  <!-- ═══════════════════════════════════════ DESCRIPTION + POOL IMAGE -->
  <section class="py-28 bg-midnight-950">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <div>
        <p class="text-amber-400 text-xs tracking-[0.4em] uppercase mb-4 flex items-center gap-3">
          <span class="w-8 h-px bg-amber-400"></span>
          The Estate
        </p>
        <h2 class="font-display text-4xl md:text-5xl text-white mb-8 leading-tight">
          Rare Dual-Structure<br /><em class="text-gradient">Luxury Compound</em>
        </h2>
        <p class="text-slate-300 leading-relaxed mb-6 text-base">{property.description}</p>
        <p class="text-slate-400 leading-relaxed text-sm mb-10">
          Positioned on a quiet tree-lined street in the coveted 90035 corridor —
          minutes from Century City, Beverly Hills, Fox Studios, and Cedars-Sinai.
          Offered unfurnished with furnishings available at an additional monthly fee.
        </p>
        <div class="flex gap-4">
          <a href="/property" class="bg-amber-400 text-midnight-950 font-semibold text-xs tracking-widest uppercase px-7 py-3.5 hover:bg-amber-300 transition-all duration-300 amber-glow-hover">
            Full Details
          </a>
          <a href="/gallery" class="border border-slate-700 text-slate-300 text-xs tracking-widest uppercase px-7 py-3.5 hover:border-amber-400 hover:text-amber-400 transition-all duration-300">
            Gallery
          </a>
        </div>
      </div>
      <div class="relative">
        <img
          src={property.images.outdoor[0]}
          alt="Heated pool at 9432 Oakmore Rd luxury rental Los Angeles Beverlywood"
          class="w-full aspect-[4/3] object-cover"
          loading="lazy"
        />
        <div class="absolute -bottom-6 -left-6 glass p-5 w-48">
          <p class="font-display text-3xl text-amber-400">~4,492</p>
          <p class="text-xs text-slate-400 tracking-widest uppercase mt-1">Sq Ft Combined</p>
        </div>
        <div class="absolute -top-4 -right-4 w-24 h-24 border border-amber-400/20"></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ LEASE SUMMARY TABLE -->
  <section class="py-24 bg-midnight-900">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-amber-400 text-xs tracking-[0.4em] uppercase mb-4 flex items-center justify-center gap-3">
          <span class="w-8 h-px bg-amber-400"></span>
          Financial Summary
          <span class="w-8 h-px bg-amber-400"></span>
        </p>
        <h2 class="font-display text-4xl text-white">Lease <em class="text-gradient">Terms</em></h2>
      </div>

      <div class="glass border border-amber-400/10 overflow-hidden">
        <!-- Table header -->
        <div class="bg-amber-400/5 border-b border-amber-400/10 px-8 py-4 flex justify-between items-center">
          <span class="text-amber-400 text-xs tracking-widest uppercase">9432 Oakmore Rd · Los Angeles CA 90035</span>
          <span class="text-slate-500 text-xs">MLS# {property.mlsNumber}</span>
        </div>

        <!-- Table rows -->
        <div class="divide-y divide-white/5">
          {[
            ['Monthly Rent', '$23,950', true],
            ['Security Deposit', '$26,850', false],
            ['Minimum Lease Term', '6 Months', false],
            ['Preferred Lease', '12+ Months', false],
            ['Furnished', 'Unfurnished (optional add-on)', false],
            ['Pets', 'Considered with conditions', false],
            ['Parking', 'Gated driveway + EV charging station', false],
            ['Utilities', 'Tenant responsible (not included)', false],
            ['Pool Maintenance', 'Tenant responsible', false],
            ['Short-Term Stays', 'Not permitted', false],
            ['Credit Report', '$49.99 — paid by tenant', false],
          ].map(([label, value, highlight]) => (
            <div class={`px-8 py-5 flex justify-between items-center ${highlight ? 'bg-amber-400/5' : ''}`}>
              <span class="text-slate-400 text-sm">{label}</span>
              <span class={`font-medium text-sm text-right ${highlight ? 'font-display text-2xl text-amber-400' : 'text-white'}`}>
                {value}
              </span>
            </div>
          ))}
        </div>

        <!-- Table footer -->
        <div class="bg-midnight-950/60 px-8 py-6 flex flex-col sm:flex-row gap-4 justify-between items-center border-t border-amber-400/10">
          <p class="text-slate-500 text-xs">Application: CAR application · Credit report · Proof of income · Submit as single PDF</p>
          <a href="/contact" class="shrink-0 bg-amber-400 text-midnight-950 font-semibold text-xs tracking-widest uppercase px-8 py-3.5 hover:bg-amber-300 transition-all duration-300 amber-glow-hover">
            Apply Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ LOCATION INTELLIGENCE VIDEO -->
  <section id="video" class="py-24 bg-midnight-950">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="text-amber-400 text-xs tracking-[0.4em] uppercase mb-4 flex items-center justify-center gap-3">
          <span class="w-8 h-px bg-amber-400"></span>
          Location Intelligence
          <span class="w-8 h-px bg-amber-400"></span>
        </p>
        <h2 class="font-display text-4xl text-white">Property Tour + <em class="text-gradient">Market Context</em></h2>
        <p class="text-slate-500 text-sm mt-3 max-w-xl mx-auto">
          Verified drive times, walkability metrics, and executive proximity data for 9432 Oakmore Rd, LA 90035
        </p>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-3 gap-px bg-midnight-800/20">

        <!-- Video player (2 cols) -->
        <div class="xl:col-span-2 relative aspect-video glass border border-amber-400/10 overflow-hidden">
          <iframe
            src={`${property.video.embedUrl}?rel=0&modestbranding=1&color=white`}
            title={property.video.title}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
            class="absolute inset-0 w-full h-full"
          ></iframe>
        </div>

        <!-- Location Intelligence panel (1 col) -->
        <div class="glass border border-white/5 p-7 flex flex-col justify-between">
          <div>
            <p class="text-amber-400 text-xs tracking-widest uppercase mb-5 flex items-center gap-2">
              <svg class="w-3 h-3" viewBox="0 0 12 12" fill="currentColor"><circle cx="6" cy="6" r="6"/></svg>
              Live Intelligence · 90035
            </p>

            <!-- Drive time table -->
            <div class="space-y-0 mb-6">
              <p class="text-slate-600 text-xs tracking-widest uppercase mb-3">Verified Drive Times</p>
              {[
                ['Century City', '8 min', '3.2 mi'],
                ['Beverly Hills', '10 min', '4.1 mi'],
                ['Fox Studios', '7 min', '2.8 mi'],
                ['Cedars-Sinai', '9 min', '3.5 mi'],
                ['Culver City', '12 min', '4.8 mi'],
                ['SoFi Stadium', '18 min', '8.1 mi'],
                ['LAX Airport', '20 min', '9.3 mi'],
                ['Santa Monica', '15 min', '7.2 mi'],
              ].map(([place, time, dist]) => (
                <div class="flex justify-between items-center py-2.5 border-b border-white/5">
                  <span class="text-slate-300 text-xs">{place}</span>
                  <div class="text-right">
                    <span class="text-amber-400 text-xs font-semibold">{time}</span>
                    <span class="text-slate-600 text-xs ml-2">{dist}</span>
                  </div>
                </div>
              ))}
            </div>

            <!-- Scores -->
            <div class="grid grid-cols-3 gap-px bg-midnight-800/40 mb-6">
              {[
                ['78', 'Walk'],
                ['61', 'Transit'],
                ['54', 'Bike'],
              ].map(([score, label]) => (
                <div class="glass-light p-3 text-center">
                  <p class="font-display text-xl text-amber-400">{score}</p>
                  <p class="text-slate-500 text-xs tracking-widest uppercase">{label}</p>
                </div>
              ))}
            </div>

            <!-- Key stats -->
            <div class="space-y-2 text-xs text-slate-500">
              <p class="flex justify-between"><span>Zip Code</span><span class="text-white">90035 — Prime West LA</span></p>
              <p class="flex justify-between"><span>Neighborhood</span><span class="text-white">Beverlywood</span></p>
              <p class="flex justify-between"><span>County</span><span class="text-white">Los Angeles</span></p>
              <p class="flex justify-between"><span>Lot Size</span><span class="text-white">7,283 sq ft</span></p>
            </div>
          </div>

          <a href="/contact" class="mt-6 block text-center bg-amber-400 text-midnight-950 font-semibold text-xs tracking-widest uppercase py-3.5 hover:bg-amber-300 transition-all duration-300 amber-glow-hover">
            Schedule Site Visit
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ PHOTO STRIP -->
  <section class="grid grid-cols-3 md:grid-cols-6 gap-px bg-midnight-950">
    {[...property.images.living.slice(0,2), ...property.images.kitchen.slice(0,2), ...property.images.primarySuite.slice(0,2)].map((src, i) => (
      <a href="/gallery" class="overflow-hidden block aspect-square">
        <img
          src={src}
          alt={`9432 Oakmore Rd interior photo ${i+1} — luxury rental Los Angeles`}
          class="w-full h-full object-cover opacity-70 hover:opacity-100 hover:scale-110 transition-all duration-700"
          loading="lazy"
        />
