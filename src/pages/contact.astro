---
import Layout from '../layouts/Layout.astro';
import property from '../data/property.json';

const { agent } = property;
---

<Layout
  title="Contact & Schedule a Showing | 9432 Oakmore Rd LA"
  description="Schedule a showing for 9432 Oakmore Rd, Beverlywood. Contact Daniel Issak at 310-770-0552 or dan.issak@gmail.com. 24-hour notice required."
>
  <section class="bg-charcoal py-20 text-center">
    <p class="text-gold text-xs tracking-[0.3em] uppercase mb-3">Get In Touch</p>
    <h1 class="font-serif text-white text-4xl md:text-5xl">Schedule a Showing</h1>
    <p class="text-white/40 mt-4 text-sm">24-hour notice required · Listing agent accompanies all showings</p>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-20 grid grid-cols-1 lg:grid-cols-2 gap-16">
    <!-- FORM -->
    <div>
      <h2 class="font-serif text-charcoal text-2xl mb-8">Inquiry Form</h2>
      <form
        name="showing-request"
        method="POST"
        action="/contact?success=true"
        class="space-y-5"
      >
        <input type="hidden" name="form-name" value="showing-request" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label for="first-name" class="block text-xs tracking-widest uppercase text-charcoal/50 mb-2">First Name *</label>
            <input
              type="text"
              id="first-name"
              name="first-name"
              required
              class="w-full border border-charcoal/20 px-4 py-3 text-sm focus:outline-none focus:border-gold bg-white"
            />
          </div>
          <div>
            <label for="last-name" class="block text-xs tracking-widest uppercase text-charcoal/50 mb-2">Last Name *</label>
            <input
              type="text"
              id="last-name"
              name="last-name"
              required
              class="w-full border border-charcoal/20 px-4 py-3 text-sm focus:outline-none focus:border-gold bg-white"
            />
          </div>
        </div>
        <div>
          <label for="email" class="block text-xs tracking-widest uppercase text-charcoal/50 mb-2">Email *</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full border border-charcoal/20 px-4 py-3 text-sm focus:outline-none focus:border-gold bg-white"
          />
        </div>
        <div>
          <label for="phone" class="block text-xs tracking-widest uppercase text-charcoal/50 mb-2">Phone</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            class="w-full border border-charcoal/20 px-4 py-3 text-sm focus:outline-none focus:border-gold bg-white"
          />
        </div>
        <div>
          <label for="move-in" class="block text-xs tracking-widest uppercase text-charcoal/50 mb-2">Desired Move-In</label>
          <input
            type="date"
            id="move-in"
            name="move-in"
            class="w-full border border-charcoal/20 px-4 py-3 text-sm focus:outline-none focus:border-gold bg-white"
          />
        </div>
        <div>
          <label for="lease-length" class="block text-xs tracking-widest uppercase text-charcoal/50 mb-2">Lease Length</label>
          <select
            id="lease-length"
            name="lease-length"
            class="w-full border border-charcoal/20 px-4 py-3 text-sm focus:outline-none focus:border-gold bg-white"
          >
            <option value="">Select…</option>
            <option value="6-months">6 Months</option>
            <option value="12-months">12 Months</option>
            <option value="12-plus">12+ Months</option>
            <option value="negotiable">Negotiable</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-xs tracking-widest uppercase text-charcoal/50 mb-2">Message</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            class="w-full border border-charcoal/20 px-4 py-3 text-sm focus:outline-none focus:border-gold bg-white resize-none"
            placeholder="Questions, preferred showing times, etc."
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full bg-gold text-charcoal font-bold text-xs tracking-widest uppercase px-6 py-4 hover:bg-gold-light transition-colors duration-200"
        >
          Send Inquiry
        </button>
        <p class="text-xs text-charcoal/40 text-center">
          Form submissions are UI-only. To ensure delivery, contact the agent directly.
        </p>
      </form>
    </div>

    <!-- CONTACT INFO -->
    <div class="space-y-8">
      <div class="bg-charcoal text-white p-8">
        <p class="text-gold text-xs tracking-widest uppercase mb-6">Direct Contact</p>
        <div class="space-y-4 text-sm">
          <div>
            <p class="text-white/40 text-xs mb-1">Agent</p>
            <p class="text-white font-medium">{agent.name}</p>
            <p class="text-white/50 text-xs">DRE# {agent.dre}</p>
          </div>
          <div>
            <p class="text-white/40 text-xs mb-1">Brokerage</p>
            <p class="text-white">{agent.company}</p>
            <p class="text-white/50 text-xs">DRE# {agent.companyDre}</p>
          </div>
          <div>
            <p class="text-white/40 text-xs mb-1">Cell</p>
            <a href={`tel:${agent.phone.replace(/-/g, '')}`} class="text-gold hover:text-gold-light transition-colors">
              {agent.phone}
            </a>
          </div>
          <div>
            <p class="text-white/40 text-xs mb-1">Direct</p>
            <a href={`tel:${agent.phoneAlt.replace(/-/g, '')}`} class="text-gold hover:text-gold-light transition-colors">
              {agent.phoneAlt}
            </a>
          </div>
          <div>
            <p class="text-white/40 text-xs mb-1">Email</p>
            <a href={`mailto:${agent.email}`} class="text-gold hover:text-gold-light transition-colors">
              {agent.email}
            </a>
          </div>
        </div>
      </div>

      <div class="border border-charcoal/10 p-6 bg-white space-y-4 text-sm">
        <p class="text-xs tracking-widest uppercase text-charcoal/40">Showing Policy</p>
        <ul class="space-y-3 text-charcoal/60">
          <li class="flex gap-3"><span class="text-gold mt-0.5">→</span> By appointment only — minimum 24-hour notice</li>
          <li class="flex gap-3"><span class="text-gold mt-0.5">→</span> Listing agent must accompany all showings</li>
          <li class="flex gap-3"><span class="text-gold mt-0.5">→</span> Schedule via ShowingTime / ShowingsPlus</li>
          <li class="flex gap-3"><span class="text-gold mt-0.5">→</span> Submit application as a single PDF (CAR application, credit report, proof of income)</li>
          <li class="flex gap-3"><span class="text-gold mt-0.5">→</span> Only complete applications reviewed</li>
        </ul>
      </div>

      <div class="border border-charcoal/10 p-6 bg-white">
        <p class="text-xs tracking-widest uppercase text-charcoal/40 mb-4">Property</p>
        <p class="font-medium text-charcoal">{property.address.street}</p>
        <p class="text-charcoal/60 text-sm">{property.address.neighborhood}</p>
        <p class="text-charcoal/60 text-sm">{property.address.city}, {property.address.state} {property.address.zip}</p>
        <p class="text-charcoal/40 text-xs mt-2">MLS# {property.mlsNumber}</p>
      </div>
    </div>
  </section>
</Layout>
