---
import property from '../data/property.json';
const { agent } = property;
---

<footer class="bg-charcoal border-t border-gold/20 py-12 mt-24">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-10 text-sm text-white/50">
    <div>
      <p class="font-serif text-gold text-base tracking-widest uppercase mb-3">Rent LA Elite</p>
      <p>9432 Oakmore Rd<br />Los Angeles, CA 90035</p>
      <p class="mt-2">Beverlywood / Pico-Robertson</p>
    </div>
    <div>
      <p class="text-white/80 font-medium mb-3 uppercase tracking-widest text-xs">Listing Agent</p>
      <p class="text-white/70">{agent.name}</p>
      <p>DRE# {agent.dre}</p>
      <p class="mt-1">{agent.company}</p>
      <p>DRE# {agent.companyDre}</p>
      <p class="mt-3">
        <a href={`tel:${agent.phone.replace(/-/g, '')}`} class="hover:text-gold transition-colors">{agent.phone}</a>
      </p>
      <p>
        <a href={`mailto:${agent.email}`} class="hover:text-gold transition-colors">{agent.email}</a>
      </p>
    </div>
    <div>
      <p class="text-white/80 font-medium mb-3 uppercase tracking-widest text-xs">Navigate</p>
      <nav class="flex flex-col gap-2">
        {[
          ['Home', '/'],
          ['Property', '/property'],
          ['Gallery', '/gallery'],
          ['About', '/about'],
          ['Contact', '/contact'],
        ].map(([label, href]) => (
          <a href={href} class="hover:text-gold transition-colors">{label}</a>
        ))}
      </nav>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-6 mt-10 pt-6 border-t border-white/10 text-xs text-white/30 flex flex-col md:flex-row justify-between gap-2">
    <p>Broker/Agent does not guarantee the accuracy of square footage, lot size, or other property information. Tenant to independently verify all details.</p>
    <p class="shrink-0">© {new Date().getFullYear()} Rent LA Elite</p>
  </div>
</footer>
